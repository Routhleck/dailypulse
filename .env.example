# ===========================================
# DailyPulse - 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填入你的 API Key

# LLM API Key（翻译功能需要，可选）
LLM_API_KEY=your_api_key_here

# LLM Base URL（可选，默认 Gemini OpenAI-compatible 端点）
# OpenAI:    https://api.openai.com/v1
# DeepSeek:  https://api.deepseek.com/v1
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# 主模型（可选）
# LLM_MODEL=gemini-2.5-flash-lite

# 是否开启中文翻译（默认 false，不翻译直接展示英文原文）
# LLM_TRANSLATE=false

# 翻译专用轻量模型（可选，不填则使用 LLM_MODEL）
# 建议用便宜的 lite 模型，翻译不需要强推理能力
# LLM_TRANSLATE_MODEL=gemini-2.0-flash-lite

# 翻译并发（可选，超时多时建议调低到 3~6）
# TRANSLATION_MAX_WORKERS=6

# -------------------------------------------
# Fallback Providers（可选）
# 顺序：Primary -> OpenAI fallback -> NVIDIA fallback -> Custom fallback
# -------------------------------------------

# OpenAI fallback（例如 gpt-5.4）
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_FALLBACK_MODEL=gpt-5.4
# OPENAI_FALLBACK_ENABLED=true

# NVIDIA fallback（示例模型 z-ai/glm5）
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODEL=z-ai/glm5
# NVIDIA_FALLBACK_ENABLED=true

# 自定义 fallback（任意 OpenAI-compatible provider）
# LLM_FALLBACK_API_KEY=your_fallback_key
# LLM_FALLBACK_BASE_URL=https://your-provider.com/v1
# LLM_FALLBACK_MODEL=your-model
